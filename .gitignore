# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
.env*.local

# credentials
google-credentials.json

# migration artifacts
/migration_package/
/migration.zip

# gas
/gas/node_modules/
/gas/tmp_gas/
/gas/gas_response.json
/gas/tmp.json

# locks
scripts/locks/

# scratch / one-off debug scripts (rootlevel)
scratch/
check_*.mjs
check_*.js
find_*.mjs
get_*.mjs
list_*.mjs
restore.mjs
delete_*.mjs
time_travel.mjs

# log files
*.txt
!README.txt

# one-off save/report scripts
scripts/save_daily_*.mjs
daily_report_*.txt
batch_label_logs.txt
vectorize_logs.txt
